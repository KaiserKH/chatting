# Server workspace example environment
# Copy these values into the repository root .env file.

JWT_ACCESS_SECRET=msgplatform_access_secret_change_in_prod
JWT_REFRESH_SECRET=msgplatform_refresh_secret_change_in_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=msgplatform_cookie_secret_change_in_prod
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1
DATABASE_URL=mysql://root:password@localhost:3306/messaging_platform
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SEED_SUPER_ADMIN_USERNAME=superadmin
SEED_SUPER_ADMIN_EMAIL=admin@platform.local
SEED_SUPER_ADMIN_PASSWORD=Admin@123456!
SEED_SUPER_ADMIN_PHONE=+10000000000
TURN_SERVER_URL=turn:openrelay.metered.ca:80
TURN_SERVER_USERNAME=openrelayproject
TURN_SERVER_CREDENTIAL=openrelayproject
